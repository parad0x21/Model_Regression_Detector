# MRDS environment configuration — copy to `.env` and fill in.
# `.env` is git-ignored and must never be committed.

# --- Secrets (canonical names, no MRDS_ prefix) ---
# Required once the OpenAI integration lands (Sprint 3+). Not needed for Sprint 1.
OPENAI_API_KEY=
# Required once Slack alerting lands (Sprint 8). Optional otherwise.
SLACK_WEBHOOK_URL=

# --- Runtime overrides (MRDS_ prefix; override config/settings.yaml) ---
# MRDS_ENV=local            # local | ci
# MRDS_LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR
# MRDS_JSON_LOGS=false      # true to emit JSON log lines
# MRDS_DATABASE_PATH=data/eval.db
# MRDS_MODEL=gpt-4o-mini
# MRDS_JUDGE_ENABLED=false  # LLM-as-judge is off by default for cost control
# MRDS_DEMO=false           # true: dashboard seeds offline demo data into an empty DB
