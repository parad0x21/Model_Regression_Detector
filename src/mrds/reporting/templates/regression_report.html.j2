<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>{{ ctx.title }}</title>
  <style>
    body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; margin: 2rem; color: #1a1a1a; }
    h1 { margin-bottom: 0.2rem; }
    .muted { color: #666; font-size: 0.9rem; }
    table { border-collapse: collapse; margin: 0.5rem 0 1.5rem; width: 100%; }
    th, td { border: 1px solid #ddd; padding: 6px 10px; text-align: left; font-size: 0.9rem; }
    th { background: #f5f5f5; }
    code { background: #f0f0f0; padding: 1px 4px; border-radius: 3px; }
    .banner { padding: 0.75rem 1rem; border-radius: 6px; font-weight: 600; margin: 1rem 0; }
    .pass { background: #e7f6ec; color: #1a7f37; }
    .warning { background: #fff4e5; color: #8a6d00; }
    .critical { background: #fde7ea; color: #b00020; }
  </style>
</head>
<body>
  <h1>{{ ctx.title }}</h1>
  <p class="muted">Generated {{ ctx.generated_at.strftime("%Y-%m-%d %H:%M:%SZ") }}</p>

  <div class="banner {{ ctx.severity }}">
    Severity: {{ ctx.severity | upper }}{% if ctx.is_blocking %} — DEPLOYMENT BLOCKED{% endif %}
  </div>

  <h2>Comparison</h2>
  <table>
    <tr><th></th><th>Baseline</th><th>Candidate</th></tr>
    <tr><th>Run ID</th><td><code>{{ ctx.baseline_run_id }}</code></td><td><code>{{ ctx.candidate_run_id }}</code></td></tr>
    <tr><th>Prompt</th><td>{{ ctx.baseline_prompt_version }}</td>
        <td>{{ ctx.candidate_prompt_version }}{% if ctx.prompt_changed %} (changed){% endif %}</td></tr>
    <tr><th>Dataset</th><td>{{ ctx.baseline_dataset_version }}</td>
        <td>{{ ctx.candidate_dataset_version }}{% if ctx.dataset_changed %} (changed){% endif %}</td></tr>
  </table>

  <h2>Summary</h2>
  <table>
    <tr><th>Warnings</th><th>Critical</th><th>Regressed</th><th>Improved</th><th>Unchanged</th></tr>
    <tr><td>{{ ctx.warning_count }}</td><td>{{ ctx.critical_count }}</td>
        <td>{{ ctx.regressed | length }}</td><td>{{ ctx.improved | length }}</td><td>{{ ctx.unchanged_count }}</td></tr>
  </table>

  <h2>Regressed metrics</h2>
  {% if ctx.regressed %}
  <table>
    <tr><th>Metric</th><th>Kind</th><th>Baseline</th><th>Candidate</th><th>Δ</th><th>Rel Δ</th><th>Severity</th><th>Reason</th></tr>
    {% for m in ctx.regressed %}
    <tr>
      <td>{{ m.name }}</td><td>{{ m.kind.value }}</td>
      <td>{{ "%.4g"|format(m.baseline_value) }}</td><td>{{ "%.4g"|format(m.candidate_value) }}</td>
      <td>{{ "%+.4g"|format(m.delta) }}</td>
      <td>{% if m.relative_delta is not none %}{{ "%+.1f"|format(m.relative_delta * 100) }}%{% else %}—{% endif %}</td>
      <td class="{{ m.severity.value }}">{{ m.severity.value | upper }}</td>
      <td>{{ m.reason }}</td>
    </tr>
    {% endfor %}
  </table>
  {% else %}
  <p class="muted">No regressed metrics.</p>
  {% endif %}

  <h2>Improved metrics</h2>
  {% if ctx.improved %}
  <table>
    <tr><th>Metric</th><th>Kind</th><th>Baseline</th><th>Candidate</th><th>Δ</th><th>Rel Δ</th></tr>
    {% for m in ctx.improved %}
    <tr>
      <td>{{ m.name }}</td><td>{{ m.kind.value }}</td>
      <td>{{ "%.4g"|format(m.baseline_value) }}</td><td>{{ "%.4g"|format(m.candidate_value) }}</td>
      <td>{{ "%+.4g"|format(m.delta) }}</td>
      <td>{% if m.relative_delta is not none %}{{ "%+.1f"|format(m.relative_delta * 100) }}%{% else %}—{% endif %}</td>
    </tr>
    {% endfor %}
  </table>
  {% else %}
  <p class="muted">No improved metrics.</p>
  {% endif %}

  <h2>Promotion status</h2>
  {% if ctx.promotion %}
  <p><strong>Eligible:</strong> {{ "yes" if ctx.promotion.eligible else "no" }}
     {% if ctx.promotion.severity %}(severity {{ ctx.promotion.severity }}){% endif %}</p>
  <ul>
    {% for reason in ctx.promotion.reasons %}<li>{{ reason }}</li>{% endfor %}
  </ul>
  {% else %}
  <p class="muted">Promotion not evaluated.</p>
  {% endif %}
</body>
</html>
